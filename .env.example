# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/famm_dev
# Used by docker-compose.yml to seed the local postgres container.
POSTGRES_USER=famm
POSTGRES_PASSWORD=replace-me-with-a-strong-local-password
POSTGRES_DB=famm_dev

# ─── Redis ───────────────────────────────────────────────────────────────────
# In production use rediss:// (TLS). Set REDIS_ALLOW_PLAINTEXT=1 only on a
# trusted private network.
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED. Generate a fresh 256-bit value per environment:
#   openssl rand -hex 32
# The app refuses to start without JWT_SECRET; there is no default.
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# ─── Twilio (SMS/Voice) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# Public base URL Twilio dials our webhook at. REQUIRED in production:
# webhook signature validation reconstructs this exact URL rather than
# trusting X-Forwarded-* headers (which an attacker reaching the origin
# directly could spoof).
TWILIO_WEBHOOK_BASE_URL=https://api.example.com

# ─── Voice channel ───────────────────────────────────────────────────────────
# Public HTTPS base used to build Twilio webhook URLs (status, transfer,
# outbound) and the wss:// stream URL embedded in TwiML.
PUBLIC_API_URL=https://api.example.com
# Fallback target for escalate_to_human when a tenant has none configured.
VOICE_ESCALATION_TARGET=+15555550100
# OpenAI Realtime model id (override for previews / GA cutovers).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# Trainer-utilization nudge floor (booked hours per week below which we
# place an outbound coaching call).
TRAINER_MIN_HOURS_PER_WEEK=10

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of exact origins permitted to call the API. REQUIRED
# in production. In dev, defaults to http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:3000

# ─── Image upload hosts ──────────────────────────────────────────────────────
# next/image is restricted to these hosts (no wildcards).
NEXT_PUBLIC_CDN_HOST=
NEXT_PUBLIC_S3_BUCKET=

# ─── Cookies ─────────────────────────────────────────────────────────────────
# Set to 1 only when running over plain HTTP locally. Otherwise auth cookies
# are issued with the Secure flag.
COOKIE_INSECURE=
