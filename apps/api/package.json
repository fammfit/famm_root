    "@famm/payments": "*",
    "hono": "^4.4.7",
    "hono-rate-limiter": "^0.4.2",
    "@hono/node-server": "^1.11.4",
    "ioredis": "^5.3.2",
    "jose": "^5.3.0",
    "bcryptjs": "^2.4.3",
    "nanoid": "^5.0.7",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@famm/config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
