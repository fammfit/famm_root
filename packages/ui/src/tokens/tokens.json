{
  "$comment": "Source of truth for design tokens. Hand-authored until the Figma Variables → Tokens Studio export pipeline is wired up (see docs/DESIGN_SYSTEM.md §4.2). After that, this file is regenerated and should not be edited by hand.",
  "$schema": "https://schemas.famm.fit/design-tokens/v1",
  "primitive": {
    "color": {
      "brand": {
        "50":  "#EEF2FF",
        "100": "#E0E7FF",
        "200": "#C7D2FE",
        "300": "#A5B4FC",
        "400": "#818CF8",
        "500": "#6366F1",
        "600": "#2E5BFF",
        "700": "#1E40AF",
        "800": "#1E3A8A",
        "900": "#172554"
      },
      "neutral": {
        "0":   "#FFFFFF",
        "50":  "#F8FAFC",
        "100": "#F1F5F9",
        "200": "#E2E8F0",
        "300": "#CBD5E1",
        "400": "#94A3B8",
        "500": "#64748B",
        "600": "#475569",
        "700": "#334155",
        "800": "#1E293B",
        "900": "#0F172A",
        "1000": "#020617"
      },
      "success": { "500": "#16A34A", "600": "#15803D" },
      "danger":  { "500": "#DC2626", "600": "#B91C1C" },
      "warning": { "500": "#D97706", "600": "#B45309" },
      "pr":      { "500": "#F59E0B", "600": "#D97706" }
    },
    "space": {
      "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px",
      "16": "64px", "20": "80px", "24": "96px"
    },
    "radius": {
      "none": "0px", "sm": "4px", "md": "8px", "lg": "12px",
      "xl": "16px", "2xl": "24px", "full": "9999px"
    },
    "font": {
      "family": {
        "sans": "InterVariable, ui-sans-serif, system-ui, sans-serif",
        "mono": "ui-monospace, SFMono-Regular, Menlo, monospace"
      },
      "size":   { "100": "12px", "200": "14px", "300": "16px", "400": "18px", "500": "20px", "600": "24px", "700": "30px", "800": "36px", "900": "48px" },
      "weight": { "regular": "400", "medium": "500", "semibold": "600", "bold": "700" }
    },
    "shadow": {
      "sm":     "0 1px 2px 0 rgb(15 23 42 / 0.05)",
      "md":     "0 4px 6px -1px rgb(15 23 42 / 0.08), 0 2px 4px -2px rgb(15 23 42 / 0.06)",
      "lg":     "0 10px 15px -3px rgb(15 23 42 / 0.10), 0 4px 6px -4px rgb(15 23 42 / 0.05)",
      "focus":  "0 0 0 3px rgb(46 91 255 / 0.45)"
    },
    "motion": {
      "duration": { "instant": "0ms", "fast": "120ms", "base": "200ms", "slow": "320ms" },
      "easing":   { "standard": "cubic-bezier(0.2, 0, 0, 1)", "emphasized": "cubic-bezier(0.3, 0, 0, 1.2)" }
    }
  },
  "semantic": {
    "light": {
      "color": {
        "surface": { "default": "{primitive.color.neutral.0}",   "raised": "{primitive.color.neutral.0}",   "sunken": "{primitive.color.neutral.50}",  "overlay": "rgb(15 23 42 / 0.55)" },
        "border":  { "subtle":  "{primitive.color.neutral.200}", "default": "{primitive.color.neutral.300}", "strong": "{primitive.color.neutral.500}" },
        "text":    { "primary": "{primitive.color.neutral.900}", "secondary": "{primitive.color.neutral.700}", "muted":   "{primitive.color.neutral.500}", "inverse": "{primitive.color.neutral.0}", "onAccent": "{primitive.color.neutral.0}" },
        "accent":  { "default": "{primitive.color.brand.600}",   "hover":  "{primitive.color.brand.700}",   "subtle": "{primitive.color.brand.50}" },
        "signal":  { "success": "{primitive.color.success.500}", "danger": "{primitive.color.danger.500}",  "warning": "{primitive.color.warning.500}", "pr": "{primitive.color.pr.500}" },
        "focusRing": "{primitive.color.brand.600}"
      }
    },
    "dark": {
      "color": {
        "surface": { "default": "{primitive.color.neutral.900}", "raised": "{primitive.color.neutral.800}", "sunken": "{primitive.color.neutral.1000}", "overlay": "rgb(2 6 23 / 0.70)" },
        "border":  { "subtle":  "{primitive.color.neutral.800}", "default": "{primitive.color.neutral.700}", "strong":  "{primitive.color.neutral.500}" },
        "text":    { "primary": "{primitive.color.neutral.50}",  "secondary": "{primitive.color.neutral.200}", "muted":  "{primitive.color.neutral.400}", "inverse": "{primitive.color.neutral.900}", "onAccent": "{primitive.color.neutral.0}" },
        "accent":  { "default": "{primitive.color.brand.500}",   "hover":  "{primitive.color.brand.400}",     "subtle": "{primitive.color.brand.900}" },
        "signal":  { "success": "{primitive.color.success.500}", "danger": "{primitive.color.danger.500}",    "warning": "{primitive.color.warning.500}", "pr": "{primitive.color.pr.500}" },
        "focusRing": "{primitive.color.brand.400}"
      }
    },
    "space": {
      "inset":  { "xs": "{primitive.space.2}", "sm": "{primitive.space.3}", "md": "{primitive.space.4}", "lg": "{primitive.space.6}", "xl": "{primitive.space.8}" },
      "stack":  { "xs": "{primitive.space.2}", "sm": "{primitive.space.3}", "md": "{primitive.space.4}", "lg": "{primitive.space.6}", "xl": "{primitive.space.10}" },
      "inline": { "xs": "{primitive.space.1}", "sm": "{primitive.space.2}", "md": "{primitive.space.3}", "lg": "{primitive.space.4}" }
    },
    "radius":    { "control": "{primitive.radius.md}", "card": "{primitive.radius.lg}", "pill": "{primitive.radius.full}" },
    "container": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" }
  }
}
