generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "tracing"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  TENANT_OWNER
  TENANT_ADMIN
  TRAINER_LEAD
  TRAINER
  STAFF
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  SUSPENDED
}

enum AuthMethod {
  PASSWORD
  MAGIC_LINK
  SMS_OTP
  OAUTH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL_REFUND
  FAILED
}

enum ServiceType {
  INDIVIDUAL
  GROUP
  WORKSHOP
  VIRTUAL
  HYBRID
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum EventType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  BOOKING_RESCHEDULED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_ISSUED
  USER_CREATED
  USER_INVITED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
  SESSION_CREATED
  SESSION_REVOKED
  MAGIC_LINK_SENT
  SMS_OTP_SENT
  INVITE_CREATED
  INVITE_ACCEPTED
  INVITE_REVOKED
  SERVICE_CREATED
  AVAILABILITY_UPDATED
  SLOT_GENERATED
  SLOT_CANCELLED
  SLOT_UPDATED
  BOOKING_HOLD_ACQUIRED
  BOOKING_HOLD_EXPIRED
  WAITLIST_JOINED
  WAITLIST_LEFT
  WAITLIST_PROMOTED
  AI_CONVERSATION_STARTED
  AI_CONVERSATION_ENDED
}

enum SlotStatus {
  AVAILABLE
  PARTIALLY_BOOKED
  FULLY_BOOKED
  CANCELLED
  BLACKOUT
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  status      TenantStatus @default(TRIAL)
  plan        TenantPlan   @default(FREE)

  stripeAccountId    String? @unique
  stripeCustomerId   String? @unique
  subscriptionId     String? @unique
  subscriptionEndsAt DateTime?

  branding TenantBranding?
  settings TenantSettings?

  users          TenantMembership[]
  locations      Location[]
  services       Service[]
  bookings       Booking[]
  availability   AvailabilityRule[]
  blockedPeriods BlockedPeriod[]
  generatedSlots GeneratedSlot[]
  webhooks       Webhook[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  events         DomainEvent[]
  aiMemories     AiMemory[]
  notifications  NotificationTemplate[]
  inviteTokens   InviteToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model TenantBranding {
  id             String  @id @default(cuid())
  tenantId       String  @unique
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#000000")
  secondaryColor String  @default("#ffffff")
  accentColor    String  @default("#3B82F6")
  fontFamily     String  @default("Inter")
  customDomain   String? @unique
  customCss      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TenantSettings {
  id                      String  @id @default(cuid())
  tenantId                String  @unique
  tenant                  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timezone                String  @default("UTC")
  currency                String  @default("USD")
  locale                  String  @default("en-US")
  bookingLeadTimeMinutes  Int     @default(60)
  bookingWindowDays       Int     @default(60)
  cancellationWindowHours Int     @default(24)
  maxConcurrentBookings   Int     @default(1)
  requirePaymentUpfront   Boolean @default(false)
  emailNotifications      Boolean @default(true)
  smsNotifications        Boolean @default(false)
  aiEnabled               Boolean @default(true)
  aiPersonaName           String  @default("Assistant")
  aiSystemPrompt          String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  phone         String?    @unique
  phoneVerified DateTime?
  firstName     String
  lastName      String
  avatarUrl     String?
  timezone      String     @default("UTC")
  status        UserStatus @default(PENDING_VERIFICATION)
  isSuperAdmin  Boolean    @default(false)

  sessions        Session[]
  accounts        OAuthAccount[]
  memberships     TenantMembership[]
  trainerProfile  TrainerProfile?
  bookingsAsClient Booking[]       @relation("ClientBookings")
  aiMemories      AiMemory[]
  aiConversations AiConversation[]
  sentInvites     InviteToken[]    @relation("InviteSender")
  waitlistEntries WaitlistEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
}

model TenantMembership {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  role        UserRole @default(CLIENT)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   String?
  invitedAt   DateTime?
  joinedAt    DateTime @default(now())
  // Explicit permission grants beyond role defaults
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Session {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String?
  authMethod   AuthMethod @default(PASSWORD)

  // Stored as hashed value; raw refresh token returned to client once
  refreshTokenHash String? @unique

  expiresAt    DateTime

  // Device fingerprinting
  deviceId     String?
  deviceName   String?

  ipAddress    String?
  userAgent    String?

  // Explicit revocation
  isRevoked     Boolean  @default(false)
  revokedAt     DateTime?
  revokedReason String?

  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([userId, tenantId])
  @@index([refreshTokenHash])
  @@index([isRevoked, expiresAt])
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scope             String?
  tokenType         String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ─── Auth Tokens ─────────────────────────────────────────────────────────────

model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  // Raw token is sent to user; only hash stored here
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  requestIp String?
  createdAt DateTime @default(now())

  @@index([email, tenantId])
  @@index([expiresAt])
}

model SmsOtp {
  id         String   @id @default(cuid())
  phone      String
  tenantId   String
  codeHash   String
  attempts   Int      @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  requestIp  String?
  createdAt  DateTime @default(now())

  @@index([phone, tenantId])
  @@index([expiresAt])
}

model InviteToken {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  role        UserRole @default(CLIENT)
  tokenHash   String   @unique
  invitedBy   String
  inviter     User     @relation("InviteSender", fields: [invitedBy], references: [id])
  message     String?
  metadata    Json?
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  revokedBy   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, email])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── Trainer Hierarchy ────────────────────────────────────────────────────────

model TrainerProfile {
  id                     String          @id @default(cuid())
  userId                 String          @unique
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                    String?
  specialties            String[]
  certifications         String[]
  leadTrainerId          String?
  leadTrainer            TrainerProfile? @relation("TrainerHierarchy", fields: [leadTrainerId], references: [id])
  subordinates           TrainerProfile[] @relation("TrainerHierarchy")
  stripeConnectAccountId String?         @unique
  stripeConnectOnboarded Boolean         @default(false)
  commissionRate         Float?
  availability           AvailabilityRule[]
  blockedPeriods         BlockedPeriod[]
  services               TrainerService[]
  bookings               Booking[]       @relation("TrainerBookings")
  generatedSlots         GeneratedSlot[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([userId])
  @@index([leadTrainerId])
}

model TrainerService {
  trainerId     String
  serviceId     String
  trainer       TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  priceOverride Float?

  @@id([trainerId, serviceId])
}

// ─── Location ────────────────────────────────────────────────────────────────

model Location {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  city           String?
  state          String?
  country        String   @default("US")
  postalCode     String?
  timezone       String   @default("UTC")
  latitude       Float?
  longitude      Float?
  isActive       Boolean  @default(true)
  isVirtual      Boolean  @default(false)
  services       Service[]
  availability   AvailabilityRule[]
  blockedPeriods BlockedPeriod[]
  bookings       Booking[]
  slots          GeneratedSlot[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id                   String      @id @default(cuid())
  tenantId             String
  tenant               Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId           String?
  location             Location?   @relation(fields: [locationId], references: [id])
  name                 String
  description          String?
  type                 ServiceType @default(INDIVIDUAL)
  durationMinutes      Int         @default(60)
  maxParticipants      Int         @default(1)
  bufferBeforeMinutes  Int         @default(0)
  bufferAfterMinutes   Int         @default(0)
  basePrice            Float       @default(0)
  currency             String      @default("USD")
  dynamicPricingConfig Json?
  isActive             Boolean     @default(true)
  isPublic             Boolean     @default(true)
  bookingRules         Json?
  trainers             TrainerService[]
  availability         AvailabilityRule[]
  bookings             Booking[]
  slots                GeneratedSlot[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
}

// ─── Availability ────────────────────────────────────────────────────────────

model AvailabilityRule {
  id         String          @id @default(cuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainerId  String?
  trainer    TrainerProfile? @relation(fields: [trainerId], references: [id])
  serviceId  String?
  service    Service?        @relation(fields: [serviceId], references: [id])
  locationId String?
  location   Location?       @relation(fields: [locationId], references: [id])
  dayOfWeek  DayOfWeek
  startTime  String
  endTime    String
  timezone   String          @default("UTC")
  isActive   Boolean         @default(true)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, trainerId])
  @@index([tenantId, serviceId])
  @@index([tenantId, dayOfWeek])
}

model BlockedPeriod {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainerId      String?
  trainer        TrainerProfile? @relation(fields: [trainerId], references: [id])
  locationId     String?
  location       Location?       @relation(fields: [locationId], references: [id])
  reason         String?
  startAt        DateTime
  endAt          DateTime
  timezone       String          @default("UTC")
  isRecurring    Boolean         @default(false)
  recurrenceRule String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, startAt, endAt])
  @@index([trainerId, startAt, endAt])
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id                    String        @id @default(cuid())
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId              String
  client                User          @relation("ClientBookings", fields: [clientId], references: [id])
  trainerId             String?
  trainer               TrainerProfile? @relation("TrainerBookings", fields: [trainerId], references: [id])
  serviceId             String
  service               Service       @relation(fields: [serviceId], references: [id])
  locationId            String?
  location              Location?     @relation(fields: [locationId], references: [id])
  status                BookingStatus @default(PENDING)
  startAt               DateTime
  endAt                 DateTime
  timezone              String
  price                 Float
  currency              String        @default("USD")
  paymentStatus         PaymentStatus @default(UNPAID)
  stripePaymentIntentId String?       @unique
  notes                 String?
  internalNotes         String?
  cancelledAt           DateTime?
  cancellationReason    String?
  cancelledBy           String?
  rescheduledFromId     String?
  rescheduledFrom       Booking?      @relation("RescheduleChain", fields: [rescheduledFromId], references: [id])
  rescheduledTo         Booking[]     @relation("RescheduleChain")
  reminders             BookingReminder[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, trainerId])
  @@index([tenantId, status])
  @@index([tenantId, startAt])
  @@index([startAt, endAt])
}

model BookingReminder {
  id          String              @id @default(cuid())
  bookingId   String
  booking     Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  channel     NotificationChannel
  scheduledAt DateTime
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
}

// ─── Domain Events ────────────────────────────────────────────────────────────

model DomainEvent {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type           EventType
  aggregateId    String
  aggregateType  String
  payload        Json
  metadata       Json?
  idempotencyKey String?   @unique
  processedAt    DateTime?
  failedAt       DateTime?
  retryCount     Int       @default(0)
  occurredAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([aggregateId])
  @@index([occurredAt])
}

// ─── AI ───────────────────────────────────────────────────────────────────────

model AiMemory {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String
  embedding  Unsupported("vector(1536)")?
  memoryType String   @default("general")
  importance Float    @default(0.5)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, userId, memoryType])
}

model AiConversation {
  id               String     @id @default(cuid())
  tenantId         String
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel          String     @default("web")
  messages         AiMessage[]
  summary          String?
  summaryEmbedding Unsupported("vector(1536)")?
  metadata         Json?
  startedAt        DateTime   @default(now())
  endedAt          DateTime?

  @@index([tenantId, userId])
  @@index([tenantId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolCalls      Json?
  toolResults    Json?
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationTemplate {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  channel   NotificationChannel
  subject   String?
  body      String
  variables String[]
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([tenantId, key, channel])
  @@index([tenantId])
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

model Webhook {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  secret    String
  events    EventType[]
  isActive  Boolean           @default(true)
  deliveries WebhookDelivery[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId])
}

model WebhookDelivery {
  id             String    @id @default(cuid())
  webhookId      String
  webhook        Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType      EventType
  payload        Json
  responseStatus Int?
  responseBody   String?
  attemptCount   Int       @default(0)
  succeededAt    DateTime?
  failedAt       DateTime?
  nextRetryAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([webhookId])
}

// ─── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String   @unique
  prefix     String
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean  @default(true)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([keyHash])
}

// ─── Scheduling ──────────────────────────────────────────────────────────────

model GeneratedSlot {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainerId    String?
  trainer      TrainerProfile? @relation(fields: [trainerId], references: [id])
  serviceId    String
  service      Service         @relation(fields: [serviceId], references: [id])
  locationId   String?
  location     Location?       @relation(fields: [locationId], references: [id])
  startsAt     DateTime
  endsAt       DateTime
  timezone     String          @default("UTC")
  status       SlotStatus      @default(AVAILABLE)
  capacity     Int             @default(1)
  bookedCount  Int             @default(0)
  holdCount    Int             @default(0)
  sourceRuleId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  waitlist     WaitlistEntry[]

  @@unique([trainerId, serviceId, startsAt])
  @@index([tenantId, startsAt, status])
  @@index([trainerId, startsAt])
  @@index([serviceId, startsAt])
  @@index([startsAt, endsAt])
  @@index([tenantId, status])
}

model WaitlistEntry {
  id         String        @id @default(cuid())
  tenantId   String
  slotId     String
  slot       GeneratedSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  position   Int
  notifiedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([slotId, userId])
  @@index([slotId, position])
  @@index([userId])
  @@index([tenantId])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  sessionId  String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  occurredAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, resource, resourceId])
  @@index([tenantId, action])
  @@index([occurredAt])
}
