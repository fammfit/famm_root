generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "tracing"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm]
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  TENANT_OWNER
  TENANT_ADMIN
  TRAINER_LEAD
  TRAINER
  STAFF
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL_REFUND
  FAILED
}

enum ServiceType {
  INDIVIDUAL
  GROUP
  WORKSHOP
  VIRTUAL
  HYBRID
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum EventType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  BOOKING_RESCHEDULED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_ISSUED
  USER_CREATED
  USER_INVITED
  SERVICE_CREATED
  AVAILABILITY_UPDATED
  AI_CONVERSATION_STARTED
  AI_CONVERSATION_ENDED
}

// ─── Tenant (root aggregate) ─────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  status      TenantStatus @default(TRIAL)
  plan        TenantPlan   @default(FREE)

  // Stripe
  stripeAccountId      String? @unique
  stripeCustomerId     String? @unique
  subscriptionId       String? @unique
  subscriptionEndsAt   DateTime?

  // Branding (white-label)
  branding    TenantBranding?

  // Settings
  settings    TenantSettings?

  // Relations
  users             TenantMembership[]
  locations         Location[]
  services          Service[]
  bookings          Booking[]
  availability      AvailabilityRule[]
  blockedPeriods    BlockedPeriod[]
  webhooks          Webhook[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  events            DomainEvent[]
  aiMemories        AiMemory[]
  notifications     NotificationTemplate[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model TenantBranding {
  id            String  @id @default(cuid())
  tenantId      String  @unique
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  logoUrl       String?
  faviconUrl    String?
  primaryColor  String  @default("#000000")
  secondaryColor String @default("#ffffff")
  accentColor   String  @default("#3B82F6")
  fontFamily    String  @default("Inter")
  customDomain  String? @unique
  customCss     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TenantSettings {
  id                    String  @id @default(cuid())
  tenantId              String  @unique
  tenant                Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  timezone              String  @default("UTC")
  currency              String  @default("USD")
  locale                String  @default("en-US")

  // Booking config
  bookingLeadTimeMinutes  Int    @default(60)
  bookingWindowDays       Int    @default(60)
  cancellationWindowHours Int    @default(24)
  maxConcurrentBookings   Int    @default(1)
  requirePaymentUpfront   Boolean @default(false)

  // Notifications
  emailNotifications    Boolean @default(true)
  smsNotifications      Boolean @default(false)

  // AI
  aiEnabled             Boolean @default(true)
  aiPersonaName         String  @default("Assistant")
  aiSystemPrompt        String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  emailVerified DateTime?
  passwordHash  String?
  phone         String?
  phoneVerified DateTime?

  firstName     String
  lastName      String
  avatarUrl     String?
  timezone      String      @default("UTC")
  status        UserStatus  @default(PENDING_VERIFICATION)

  // Global super-admin flag (no tenant)
  isSuperAdmin  Boolean     @default(false)

  // Auth
  sessions      Session[]
  accounts      OAuthAccount[]

  // Tenant memberships (user can belong to multiple tenants)
  memberships   TenantMembership[]

  // Trainer profile (optional)
  trainerProfile TrainerProfile?

  // Client bookings
  bookingsAsClient Booking[] @relation("ClientBookings")

  // AI memory (per-user, isolated)
  aiMemories    AiMemory[]
  aiConversations AiConversation[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([email])
  @@index([phone])
}

model TenantMembership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(CLIENT)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  invitedBy String?
  invitedAt DateTime?
  joinedAt  DateTime @default(now())

  // Tenant-scoped permissions override
  permissions String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime

  ipAddress    String?
  userAgent    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scope             String?
  tokenType         String?
  idToken           String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ─── Trainer Hierarchy ───────────────────────────────────────────────────────

model TrainerProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio         String?
  specialties String[]
  certifications String[]

  // Hierarchy: a trainer can have a lead trainer
  leadTrainerId String?
  leadTrainer   TrainerProfile?  @relation("TrainerHierarchy", fields: [leadTrainerId], references: [id])
  subordinates  TrainerProfile[] @relation("TrainerHierarchy")

  // Stripe Connect for direct payouts
  stripeConnectAccountId String? @unique
  stripeConnectOnboarded Boolean @default(false)

  // Commission rate (overrides tenant default)
  commissionRate Float?

  // Availability
  availability     AvailabilityRule[]
  blockedPeriods   BlockedPeriod[]

  // Services this trainer can deliver
  services  TrainerService[]

  // Bookings as trainer
  bookings  Booking[] @relation("TrainerBookings")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([leadTrainerId])
}

model TrainerService {
  trainerId String
  serviceId String

  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Trainer-specific pricing override
  priceOverride Float?

  @@id([trainerId, serviceId])
}

// ─── Location ────────────────────────────────────────────────────────────────

model Location {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  address     String?
  city        String?
  state       String?
  country     String  @default("US")
  postalCode  String?
  timezone    String  @default("UTC")

  latitude    Float?
  longitude   Float?

  isActive    Boolean @default(true)
  isVirtual   Boolean @default(false)

  services    Service[]
  availability AvailabilityRule[]
  blockedPeriods BlockedPeriod[]
  bookings    Booking[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId  String?
  location    Location?   @relation(fields: [locationId], references: [id])

  name        String
  description String?
  type        ServiceType @default(INDIVIDUAL)

  durationMinutes    Int    @default(60)
  maxParticipants    Int    @default(1)
  bufferBeforeMinutes Int   @default(0)
  bufferAfterMinutes  Int   @default(0)

  // Pricing
  basePrice   Float   @default(0)
  currency    String  @default("USD")

  // Dynamic pricing config (JSON blob)
  dynamicPricingConfig Json?

  isActive    Boolean @default(true)
  isPublic    Boolean @default(true)

  // Booking rules (JSON blob for flexibility)
  bookingRules Json?

  trainers    TrainerService[]
  availability AvailabilityRule[]
  bookings    Booking[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
}

// ─── Availability Engine ─────────────────────────────────────────────────────

model AvailabilityRule {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Scope: can apply at trainer, service, or location level
  trainerId   String?
  trainer     TrainerProfile? @relation(fields: [trainerId], references: [id])
  serviceId   String?
  service     Service?        @relation(fields: [serviceId], references: [id])
  locationId  String?
  location    Location?       @relation(fields: [locationId], references: [id])

  // Recurring weekly rule
  dayOfWeek   DayOfWeek
  startTime   String    // "HH:MM" in location/trainer timezone
  endTime     String    // "HH:MM"
  timezone    String    @default("UTC")

  isActive    Boolean   @default(true)

  // Validity window
  validFrom   DateTime?
  validUntil  DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, trainerId])
  @@index([tenantId, serviceId])
  @@index([tenantId, dayOfWeek])
}

model BlockedPeriod {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  trainerId   String?
  trainer     TrainerProfile? @relation(fields: [trainerId], references: [id])
  locationId  String?
  location    Location?       @relation(fields: [locationId], references: [id])

  reason      String?
  startAt     DateTime
  endAt       DateTime
  timezone    String   @default("UTC")

  // Recurring blocks
  isRecurring Boolean  @default(false)
  recurrenceRule String? // iCal RRULE string

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, startAt, endAt])
  @@index([trainerId, startAt, endAt])
}

// ─── Booking Engine ──────────────────────────────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId    String
  client      User          @relation("ClientBookings", fields: [clientId], references: [id])

  trainerId   String?
  trainer     TrainerProfile? @relation("TrainerBookings", fields: [trainerId], references: [id])

  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])

  locationId  String?
  location    Location?     @relation(fields: [locationId], references: [id])

  status      BookingStatus @default(PENDING)

  // Time (always UTC)
  startAt     DateTime
  endAt       DateTime
  timezone    String        // Client's local timezone at time of booking

  // Pricing snapshot at booking time
  price       Float
  currency    String        @default("USD")

  // Payment
  paymentStatus PaymentStatus @default(UNPAID)
  stripePaymentIntentId String? @unique

  // Metadata
  notes       String?
  internalNotes String?

  // Cancellation
  cancelledAt  DateTime?
  cancellationReason String?
  cancelledBy  String?

  // Reschedule history
  rescheduledFromId String?
  rescheduledFrom   Booking? @relation("RescheduleChain", fields: [rescheduledFromId], references: [id])
  rescheduledTo     Booking[] @relation("RescheduleChain")

  // Reminders sent
  reminders   BookingReminder[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, trainerId])
  @@index([tenantId, status])
  @@index([tenantId, startAt])
  @@index([startAt, endAt])
}

model BookingReminder {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  channel     NotificationChannel
  scheduledAt DateTime
  sentAt      DateTime?

  createdAt   DateTime @default(now())
}

// ─── Domain Events (event sourcing) ─────────────────────────────────────────

model DomainEvent {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type        EventType
  aggregateId String
  aggregateType String

  payload     Json
  metadata    Json?

  // For idempotency
  idempotencyKey String? @unique

  processedAt DateTime?
  failedAt    DateTime?
  retryCount  Int       @default(0)

  occurredAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([aggregateId])
  @@index([occurredAt])
}

// ─── AI Memory (per-user, per-tenant isolated) ────────────────────────────────

model AiMemory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  content     String
  // pgvector embedding — 1536 dims for text-embedding-3-small
  embedding   Unsupported("vector(1536)")?

  memoryType  String   @default("general")
  importance  Float    @default(0.5)

  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, userId, memoryType])
}

model AiConversation {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel     String   @default("web") // web | sms | voice

  messages    AiMessage[]

  summary     String?
  // Embedding of conversation summary for RAG
  summaryEmbedding Unsupported("vector(1536)")?

  metadata    Json?

  startedAt   DateTime @default(now())
  endedAt     DateTime?

  @@index([tenantId, userId])
  @@index([tenantId])
}

model AiMessage {
  id              String         @id @default(cuid())
  conversationId  String
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role            String         // user | assistant | system | tool
  content         String
  toolCalls       Json?
  toolResults     Json?

  // Token tracking for billing
  inputTokens     Int?
  outputTokens    Int?

  createdAt       DateTime       @default(now())

  @@index([conversationId])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model NotificationTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key       String   // e.g., "booking_confirmed"
  channel   NotificationChannel
  subject   String?
  body      String
  variables String[] // list of required template variables

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key, channel])
  @@index([tenantId])
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

model Webhook {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url         String
  secret      String
  events      EventType[]
  isActive    Boolean  @default(true)

  deliveries  WebhookDelivery[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  eventType   EventType
  payload     Json

  responseStatus Int?
  responseBody   String?

  attemptCount   Int      @default(0)
  succeededAt    DateTime?
  failedAt       DateTime?
  nextRetryAt    DateTime?

  createdAt   DateTime @default(now())

  @@index([webhookId])
}

// ─── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  keyHash     String   @unique
  prefix      String   // First 8 chars shown to user

  scopes      String[]

  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)

  createdBy   String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([keyHash])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId      String?
  action      String   // e.g., "booking.create"
  resource    String   // e.g., "Booking"
  resourceId  String?

  before      Json?
  after       Json?

  ipAddress   String?
  userAgent   String?
  requestId   String?

  occurredAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, resource, resourceId])
  @@index([occurredAt])
}
